{
  "mcpServers": {
    "wger-agent": {
      "command": "uv",
      "args": [
        "run",
        "wger-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "BODYTOOL": "True",
        "EXERCISETOOL": "True",
        "NUTRITIONTOOL": "True",
        "ROUTINECONFIGTOOL": "True",
        "ROUTINETOOL": "True",
        "USERTOOL": "True",
        "WGER_ACCESS_TOKEN": "your_api_token_here",
        "WGER_TOKEN": "your_api_token_here",
        "WGER_URL": "http://localhost:8000",
        "WGER_VERIFY": "True",
        "WORKOUTTOOL": "True"
      }
    }
  }
}
